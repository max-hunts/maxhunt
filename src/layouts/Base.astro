---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Shiba from '../components/Shiba.tsx';
import Analytics from '../components/Analytics.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.ogImage,
  type = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: SITE.domain,
  image: new URL(SITE.ogImage, Astro.site).href,
  jobTitle: 'Software Developer',
  description: SITE.description,
  knowsAbout: ['Software development', 'Hardware', 'Mechatronics', 'Product design'],
  sameAs: [SITE.linkedin, SITE.github],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personLd)}
    />

    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <div class="gridfx" aria-hidden="true" transition:persist></div>
    <slot />
    <Shiba client:only="react" transition:persist />
  </body>
</html>
